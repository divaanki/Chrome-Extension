
{
    "manifest_version": 3,
    "version": "1.0",
    "name" : "SaveMyLinks",
    "action":
    {
        "default_popup": "index.html",
        "default_icon": "icon.PNG"
    },
    "permissions": [
        "tabs"
    ],
    "web_accessible_resources": [
        {
            "resources": ["delete_icon.png", "icon.PNG"],
            "matches": ["<all_urls>"]
        }
    ]
}